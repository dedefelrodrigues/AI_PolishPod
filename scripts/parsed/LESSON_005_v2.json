    {
      "type": "dialogue_pl",
      "speaker": "man",
      "text": "Dzień dobry! Jaka piękna pogoda dzisiaj."
    },
    {
      "type": "dialogue_pl",
      "speaker": "woman",
      "text": "Tak, jest ciepło i słońce świeci. Pogoda jest idealna."
    },
    {
      "type": "dialogue_pl",
      "speaker": "man",
      "text": "Przyroda budzi się do życia. Wiosna jest naprawdę piękna."
